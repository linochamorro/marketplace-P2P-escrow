# .env.example — Variables de entorno requeridas para el frontend (EasyMarket)
#
# Copiar este archivo como `.env.local` para desarrollo local:
#   cp .env.example .env.local
#
# NUNCA guardes claves secretas o credenciales reales de producción en este archivo
# ni en ningún archivo subido al repositorio Git.

# ─── API del Backend ──────────────────────────────────────────────────────────
# URL base del servidor backend de Spring Boot.
# En desarrollo local suele ser: http://localhost:8080
# En producción (Vercel) debe apuntar a la URL de Railway.
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Stripe Configuración ─────────────────────────────────────────────────────
# Clave pública de Stripe (Publishable Key) en modo test/sandbox.
# Esta clave es segura de exponer en el frontend (lado del cliente).
# Obtener de: Dashboard de Stripe -> Developers -> API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
